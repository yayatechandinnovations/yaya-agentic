# Copy this file to `.env` (which is gitignored) and fill in real values.
#
#   cp .env.example .env
#   docker compose up --build
#
# Without these, the app boots but the playground talks to a deterministic
# stub LLM and the deterministic-hash embedding stub — useful for testing
# the engine, useless for real grounded answers.

# Anthropic API key for the chat LLM (claude-sonnet-4-6 by default).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI API key for embeddings (text-embedding-3-small).
# Only needed when YAYA_EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=

# Which embedding provider to wire. `openai` uses the real model
# (text-embedding-3-small); set to `none` to fall back to the
# deterministic-hash stub for offline / no-key dev.
YAYA_EMBEDDING_PROVIDER=openai

# Which chat LLM client to wire:
#   anthropic  — Claude (requires ANTHROPIC_API_KEY)
#   openai     — GPT-4o-mini by default (requires OPENAI_API_KEY)
#   stub       — deterministic pattern-matching client, offline/no-key dev
YAYA_LLM_PROVIDER=anthropic

# Optional: override the OpenAI chat model when YAYA_LLM_PROVIDER=openai.
# OPENAI_CHAT_MODEL=gpt-4o

# Dev convenience: allow anonymous sessions on /v1/sessions/*. Production
# MUST set this to false and wire a real Authenticator (M5).
YAYA_AUTH_ALLOW_ANONYMOUS=true

# Override only if your Flutter web container needs to reach the backend
# under a different name (e.g. when fronting both behind a reverse proxy).
# BACKEND_BASE_URL=http://localhost:8080
